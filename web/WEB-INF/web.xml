<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
    
    <display-name>ProcureGov</display-name>
    
    <!-- SMTP Configuration for JavaMail (Module 6: Supplier Email Notification) -->
    <context-param>
        <param-name>smtpHost</param-name>
        <param-value>smtp.gmail.com</param-value>
    </context-param>
    <context-param>
        <param-name>smtpPort</param-name>
        <param-value>587</param-value>
    </context-param>
    <context-param>
        <param-name>smtpUser</param-name>
        <!-- <param-value>my-email@gmail.com</param-value> -->
        <param-value>significant.hacks@gmail.com</param-value>
    </context-param>
    <context-param>
        <param-name>smtpPassword</param-name>
        <!-- <param-value>my-16-char-app-password</param-value> -->
        <param-value>gafcllurpkntpzmj</param-value>
    </context-param>
    
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    <error-page>
        <error-code>400</error-code>
        <location>/pages/error/400.jsp</location>
    </error-page>
    <error-page>
        <error-code>401</error-code>
        <location>/pages/error/401.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/pages/error/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/pages/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>408</error-code>
        <location>/pages/error/408.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/pages/error/500.jsp</location>
    </error-page>

    <resource-ref>
        <description>DB Connection Pool</description>
        <res-ref-name>jdbc/ProcureGovDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

    <resource-ref>
        <description>Mail Session</description>
        <res-ref-name>mail/ProcureGovMail</res-ref-name>
        <res-type>javax.mail.Session</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

    <!-- File Upload Configuration -->
    <!-- Configurable upload directory - override in context.xml for production -->
    <context-param>
        <param-name>uploadDirectory</param-name>
        <param-value>${user.home}/ProcureGov/uploads</param-value>
    </context-param>

    <!-- ==================== AUTH SERVLETS ==================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/reset-password</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ConfirmAccountServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.ConfirmAccountServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConfirmAccountServlet</servlet-name>
        <url-pattern>/confirm-account</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResendConfirmationServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.ResendConfirmationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResendConfirmationServlet</servlet-name>
        <url-pattern>/resend-confirmation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EmailVerificationServlet</servlet-name>
        <servlet-class>com.procuregov.controller.auth.EmailVerificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmailVerificationServlet</servlet-name>
        <url-pattern>/email-verify</url-pattern>
    </servlet-mapping>

    <!-- ==================== OFFICER SERVLETS ==================== -->
    <servlet>
        <servlet-name>OfficerDashboardServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.OfficerDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OfficerDashboardServlet</servlet-name>
        <url-pattern>/officer-dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CreateTenderServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.CreateTenderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CreateTenderServlet</servlet-name>
        <url-pattern>/create-tender</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TenderStatusServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.TenderStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TenderStatusServlet</servlet-name>
        <url-pattern>/tender-status</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditTenderServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.EditTenderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditTenderServlet</servlet-name>
        <url-pattern>/edit-tender</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ManageTendersServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.ManageTendersServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ManageTendersServlet</servlet-name>
        <url-pattern>/manage-tenders</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EvaluationListServlet</servlet-name>
        <servlet-class>com.procuregov.controller.evaluator.EvaluationListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EvaluationListServlet</servlet-name>
        <url-pattern>/evaluations</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AwardContractServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.AwardContractServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AwardContractServlet</servlet-name>
        <url-pattern>/award-contract</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BidReportServlet</servlet-name>
        <servlet-class>com.procuregov.controller.officer.BidReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BidReportServlet</servlet-name>
        <url-pattern>/bid-report</url-pattern>
    </servlet-mapping>

    <!-- ==================== SUPPLIER SERVLETS ==================== -->
    <servlet>
        <servlet-name>SupplierDashboardServlet</servlet-name>
        <servlet-class>com.procuregov.controller.supplier.SupplierDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SupplierDashboardServlet</servlet-name>
        <url-pattern>/supplier-dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OpenTendersServlet</servlet-name>
        <servlet-class>com.procuregov.controller.supplier.OpenTendersServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OpenTendersServlet</servlet-name>
        <url-pattern>/open-tenders</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TenderDetailServlet</servlet-name>
        <servlet-class>com.procuregov.controller.supplier.TenderDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TenderDetailServlet</servlet-name>
        <url-pattern>/tender-detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitBidServlet</servlet-name>
        <servlet-class>com.procuregov.controller.supplier.SubmitBidServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitBidServlet</servlet-name>
        <url-pattern>/submit-bid</url-pattern>
    </servlet-mapping>

    <!-- ==================== EVALUATOR SERVLETS ==================== -->
    <servlet>
        <servlet-name>EvaluatorDashboardServlet</servlet-name>
        <servlet-class>com.procuregov.controller.evaluator.EvaluatorDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EvaluatorDashboardServlet</servlet-name>
        <url-pattern>/evaluator-dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EvaluationPanelServlet</servlet-name>
        <servlet-class>com.procuregov.controller.evaluator.EvaluationPanelServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EvaluationPanelServlet</servlet-name>
        <url-pattern>/evaluation-panel</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitScoreServlet</servlet-name>
        <servlet-class>com.procuregov.controller.evaluator.SubmitScoreServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitScoreServlet</servlet-name>
        <url-pattern>/submit-score</url-pattern>
    </servlet-mapping>

    <!-- ==================== COMMON SERVLETS ==================== -->
    <servlet>
        <servlet-name>DownloadServlet</servlet-name>
        <servlet-class>com.procuregov.controller.common.DownloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DownloadServlet</servlet-name>
        <url-pattern>/download</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AwardNoticeServlet</servlet-name>
        <servlet-class>com.procuregov.controller.common.AwardNoticeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AwardNoticeServlet</servlet-name>
        <url-pattern>/award-notice</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.procuregov.controller.common.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <!-- ==================== FILTERS ==================== -->
    <filter>
        <filter-name>AuthRedirectFilter</filter-name>
        <filter-class>com.procuregov.filter.AuthRedirectFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthRedirectFilter</filter-name>
        <url-pattern>/pages/officer/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthRedirectFilter</filter-name>
        <url-pattern>/pages/supplier/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthRedirectFilter</filter-name>
        <url-pattern>/pages/evaluator/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthRedirectFilter</filter-name>
        <url-pattern>/pages/profile/*</url-pattern>
    </filter-mapping>

    <!-- ==================== LISTENERS ==================== -->
    <listener>
        <listener-class>com.procuregov.listener.DBInitListener</listener-class>
    </listener>
    <listener>
        <listener-class>com.procuregov.util.OnlineUserTracker</listener-class>
    </listener>

</web-app>
